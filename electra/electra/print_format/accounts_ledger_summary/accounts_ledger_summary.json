 "html": "<div class=\"container\">\n    <header id='header-html'>\n    {% set letter_head = frappe.db.get_value(\"Letter Head\",'Electra',['image']) %}\n    <img src=\"{{ letter_head }}\" />\n\n</header>\n   <div class=\"print-heading\"><h2 style=\"text-transform:uppercase\"><b><center>Accounts Receivable</center></b></h2></div>\n   <table border=1  width=\"100%\">\n    {% set customer_credit_limit = frappe.db.get_value(\"Customer Credit Limit\", {\"parent\": doc.customer},\"credit_limit\") %}\n    <tr>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-left-style:hidden; border-bottom-style:hidden; border-top-style:hidden\"><b>SOA</b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden; border-bottom-style:hidden; border-top-style:hidden\" nowrap>{{ doc.customer or '' }}</td>\n        <td width=\"25%\" style=\"border-right-style:hidden; border-bottom-style:hidden; border-top-style:hidden\"><b>Credit Limit</b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-bottom-style:hidden; border-top-style:hidden\">{{ customer_credit_limit }}</td>\n    </tr>\n    <tr>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-left-style:hidden; border-bottom-style:hidden\"><b>Division</b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden; border-bottom-style:hidden\" nowrap>{{ doc.company or '' }}</td>\n        <td width=\"25%\" style=\"border-right-style:hidden; border-bottom-style:hidden\"><b>Posting Date</b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-bottom-style:hidden\">{{frappe.utils.format_date(frappe.utils.today()) or ''}}</td>\n    </tr>\n    <tr>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-left-style:hidden;\"><b>Due Date Untill</b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden;\" nowrap>{{ frappe.utils.format_date(doc.from_date or '' )}}</td>\n        <td width=\"25%\" style=\"border-right-style:hidden;border-right-style:hidden\"><b></b></td>\n        <td width=\"25%\" style=\"border-right-style:hidden\" ></td>\n    </tr>\n</table>\n{% set data = get_accounts_ledger(doc)%}\n{{data}}\n</div>\n<footer id=\"footer-html\" class=\"footer-html\">\n\n    {% set footer = frappe.db.get_value(\"Letter Head\",\"Electra\",['footer']) %}\n                {{ footer }}\n                <div class = \"foot\">             \nPage <span class='page'></span> of \n    <span class='topage'></span>  \n</div>\n                </footer>\n",
