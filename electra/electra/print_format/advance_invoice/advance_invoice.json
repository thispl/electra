 "html": "<script>\n  function subst() {\n      var vars = {};\n      var query_strings_from_url = document.location.search.substring(1).split('&');\n      for (var query_string in query_strings_from_url) {\n          if (query_strings_from_url.hasOwnProperty(query_string)) {\n              var temp_var = query_strings_from_url[query_string].split('=', 2);\n              vars[temp_var[0]] = decodeURI(temp_var[1]);\n          }\n      }\n      var css_selector_classes = ['page', 'frompage', 'topage', 'webpage', 'section', 'subsection', 'date', 'isodate', 'time', 'title', 'doctitle', 'sitepage', 'sitepages'];\n      for (var css_class in css_selector_classes) {\n          if (css_selector_classes.hasOwnProperty(css_class)) {\n              var element = document.getElementsByClassName(css_selector_classes[css_class]);\n              for (var j = 0; j < element.length; ++j) {\n                  element[j].textContent = vars[css_selector_classes[css_class]];\n              }\n          }\n      }\n  }\n  </script>\n<header id='header-html'>\n    {% set letter_head = frappe.db.get_value(\"Letter Head\",doc.letter_head,['image']) %}\n    <img src=\"{{ letter_head }}\" />\n    \n  \n\n<div class=\"print-heading\"><h2 style=\"text-transform:uppercase\"><b><center>Proforma Invoice</center></b></h2>\t\n\t\n    </div> \n\t\t\n\n<div class = \"row\">\n    <div class = \"column\"> \n    <table style = \"\">\n\n    <tr>\n        {% if doc.customer %}\n        <td colspan =3 style = 'line-height: .9;'><b>Customer</b></td>\n        <td colspan =2 style = 'line-height: .9;'> {{doc.customer or \"\"}}</td>\n        {% endif %}\n        \n    </tr>\n    <tr>\n        {% if doc.po_no %}\n        <td colspan =3 style = 'line-height: .9;'><b>Customer LPO No</b></td>\n        <td colspan =2 style = 'line-height: .9;'> {{doc.po_no or \"\"}}</td>\n        {% endif %}\n    </tr>\n    <tr>\n        {% if doc.po_date %}\n        <td colspan =3 style = 'line-height: .9;'><b>Customer LPO Date</b></td>\n        <td colspan =2 style = 'line-height: .9;'> {{doc.po_date or \"\"}}</td>\n        {% endif %}\n    </tr>\n    <tr>\n        {% if doc.address_display %}\n        <td colspan =3 style = 'line-height: .9;'><b>Address</b></td>\n        <td colspan =2 style = 'line-height: 1.2;'>{{doc.address_display or ''}}</td>\n        {% endif %}\n        \n    </tr>\n   \n\n</table>\n</div>\n<div class = \"column\">\n<table>\n    <tr>\n        {% if doc.sales_order %}\n        <td colspan =3 style = 'line-height: .9;'><b>Sales Order</b></td>\n        <td colspan =2 style = 'line-height: .9;'> {{doc.sales_order or \"\"}}</td>\n        {% endif %}\n    </tr>\n    <tr>\n        {% if doc.transaction_date %}\n        <td colspan =3 style = 'border:none;line-height: .9;'><b>Sales Order Date</b></td>\n        <td colspan =2 style = 'border:none;line-height: .9;'> {{doc.get_formatted('transaction_date') or ''}}</td>\n        {% endif %}\n    </tr>\n    <tr>\n       \n        {% if doc.name %}\n        <td colspan =3 style = 'border:none;line-height: .9;'><b>Invoice No</b></td>\n        <td colspan =2 style = 'border:none;line-height: .9;'> {{doc.name or ''}}</td>\n    {% endif %}\n        \n    </tr>\n    <tr>\n       \n        {% if doc.project %}\n        <td colspan =3 style = 'border:none;line-height: .9;'><b>Project</b></td>\n        <td colspan =2 style = 'border:none;line-height: .9;'> {{doc.project or ''}}</td>\n    {% endif %}\n        \n    </tr>\n   \n</table>\n</div>\n</div>\n</header>\n\n<table  border=\"1\" style = \"width:100%\" >\n    <thead>\n            {% if doc.letter_head == \"Electra\" or doc.letter_head == \"Al - Shaghairi Trading and Contracting Company W.L.L (ELECTRA)\" %}\n\n    <tr>\n            <td style ='background-color:#e35310;color:white'>Sl No</td>\n            <td colspan =2 style ='text-align:center;background-color:#e35310;color:white'>Item Code</td>\n            <td colspan =3 style ='text-align:center;background-color:#e35310;color:white'>Scope of Work</td>\n            <td colspan =1 style ='text-align:center;background-color:#e35310;color:white'>Qty</td>\n            <td colspan =1 style ='width:10px;background-color:#e35310;color:white'>Unit</td>\n            <td style ='width:30px;text-align:center;background-color:#e35310;color:white'>Rate</td>\n            <td style ='width:80px;text-align:center;background-color:#e35310;color:white'>Amount</td>\n           \n    </tr>\n         {% elif doc.letter_head == \"KINGFISHER TRADING AND CONTRACTING COMPANY\" %}\n    \n    <tr>\n            <td style ='background-color:#f10d5c;color:white'>Sl No</td>\n            <td colspan =2 style ='text-align:center;background-color:#f10d5c;color:white'>Item Code</td>\n            <td colspan =3 style ='text-align:center;background-color:#f10d5c;color:white'>Scope of Work</td>\n            <td colspan =1 style ='text-align:center;background-color:#f10d5c;color:white'>Qty</td>\n            <td colspan =1 style ='width:10px;background-color:#f10d5c;color:white'>Unit</td>\n            <td style ='width:30px;text-align:center;background-color:#f10d5c;color:white'>Rate</td>\n            <td style ='width:80px;text-align:center;background-color:#f10d5c;color:white'>Amount</td>\n           \n    </tr>\n    {% else %}\n    \n    <tr>\n            <td style ='background-color:#064C91;color:white'>Sl No</td>\n            <td colspan =2 style ='text-align:center;background-color:#064C91;color:white'>Item Code</td>\n            <td colspan =3 style ='text-align:center;background-color:#064C91;color:white'>Scope of Work</td>\n            <td colspan =1 style ='text-align:center;background-color:#064C91;color:white'>Qty</td>\n            <td colspan =1 style ='width:10px;background-color:#064C91;color:white'>Unit</td>\n\n            <td style ='width:30px;text-align:center;background-color:#064C91;color:white'>Rate</td>\n            <td colspan =1 style ='width:80px;text-align:center;background-color:#064C91;color:white'>Amount</td>\n           \n    </tr>\n    {% endif %}\n        </thead>\n         \t{%- for item in doc.scope_of_work -%}\n         \t<tbody>\n        <tr>\n            <td >{{loop.index}}</td>\n            <td colspan =2>{{item.msow}}</td>\n            <td colspan =3>{{item.msow_desc}}</td>\n            <td colspan =1 style =text-align:right;>{{item.qty}}</td>\n            <td colspan =1 style = \"width:10px\">{{item.unit}}</td>\n            <td style =width:30px;text-align:right;>{{item.unit_price}}</td>\n            <td style =width:80px;text-align:right;>{{\"{:,.2f}\". format(item.total_bidding_price |float)}}</td>\n        </tr>\n         </tbody>\n        \t{%- endfor -%}\n     <tr>\n            <!--<td colspan =8>{{doc.delivery_note_list or ''}}</td>-->\n            <td colspan =9 style =text-align:right;><b>Contract Value </b></td>\n            <td  style =text-align:right;>{{\"{:,.2f}\".format(doc.total_bidding_price | float)}}</td>\n        </tr>\n        <tr>\n            <td colspan =8><b>Amount in words :</b> {{doc.advance_words}}</td>\n            {% if doc.percent %}\n            <td colspan =1><b>Advance {{doc.percent | int}}%</b></td>\n            {% else %}\n            <td colspan =1><b>Advance</b></td>\n            {% endif %}\n            <td  style =text-align:right;>{{\"{:,.2f}\". format(doc.advance_amount1 |float)}}</td>\n        </tr>\n        \n        <!--{% if doc.advance_type==\"Normal Advance\" %}-->\n        <!--<tr>-->\n        <!--<td colspan =8><b></b> </td>-->\n        <!--<td colspan =1><b>{{doc.normal_advance_percentage | int}} % Advance</b></td>-->\n        <!--<td colspan =1 style = 'text-align:right'>{{\"{:,.2f}\".format(doc.normal_advance_value1  |float)}}</td>-->\n        <!--</tr>-->\n        <!--{% endif %}-->\n        <!-- {% if doc.advance_type==\"Recoverable Advance\" %}-->\n        <!--<tr>-->\n        <!--<td colspan =8><b></b> </td>-->\n        <!--<td colspan =1><b>{{doc.advance_percentage | int}} % Advance</b></td>-->\n        <!--<td colspan =1 style = 'text-align:right'>{{\"{:,.2f}\".format(doc.currency_hnzl  |float)}}</td>-->\n        <!--</tr>-->\n        <!--{% endif %}-->\n        \n        <!--{% if doc.payment_schedule_2s %}-->\n        <!--<tr>-->\n        <!--    <td colspan =8><b></b> </td>-->\n        <!--     <td colspan =1><b>{{doc.payment_schedule_2s[0].percentage | int}} % Advance</b></td>-->\n        <!--    <td colspan =1 style = 'text-align:right'>{{\"{:,.2f}\".format(doc.payment_schedule_2s[0].value  |float)}}</td>-->\n        <!--</tr>-->\n        <!--{% endif %}-->\n        <!--<tr>-->\n        <!--    {% if not doc.discount_amount == 0.00 %}-->\n        <!--    <td colspan =8></td>-->\n            \n      \n        <!-- <td colspan =1><b>Discount</b></td>-->\n          \n        <!--    <td  colspan =1 style =text-align:right;>{{\"{:,.2f}\". format(doc.discount_amount |float)}}</td>-->\n        <!--   </tr> -->\n        <!--   {% endif %} -->\n        \n</table>\n\n<!--{% if doc.packed_items_check == 1 %}-->\n<!--<h4>Packed List</h4>-->\n<!--<table border=\"1\" style = \"width:100%\" >-->\n<!--        <thead>-->\n<!--        {% if doc.letter_head == \"Electra\" or doc.letter_head == \"Al - Shaghairi Trading and Contracting Company W.L.L (ELECTRA)\" %}-->\n        \n<!--         <tr >-->\n<!--            <td style ='text-align:center;background-color:#e35310;color:white'>Sl No</td>-->\n<!--            <td style ='text-align:center;background-color:#e35310;color:white'>Parent Item</td>-->\n<!--            <td style ='text-align:center;background-color:#e35310;color:white'>Item Code</td>-->\n<!--            <td style ='text-align:center;background-color:#e35310;color:white'>Description</td>-->\n<!--            <td style ='text-align:center;background-color:#e35310;color:white'>Qty</td>-->\n<!--        </tr> -->\n<!--         {% elif doc.letter_head == \"KINGFISHER TRADING AND CONTRACTING COMPANY\" %}-->\n<!--        <tr>-->\n<!--            <td style ='text-ali