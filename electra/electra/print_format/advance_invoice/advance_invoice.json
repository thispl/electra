BQA 0000 0000 4020 436181 001<br>\n                CBQAQAQA\n            </td>\n        </tr>\n        {% elif doc.letter_head == \"MARAZEEM SECURITY SERVICES\" %}\n            \n        <tr>\n            <td>Beneficiary Name : <br>\n                Beneficiary Bank  : <br>\n                Bank Address  :<br><br><br>\n                Account Number  :<br>\n                IBAN Number  :<br>\n                Swift Code :<br>\n            </td>\n            <td>MARAZEEM SECURITY SERVICES<br>\n                QNB<br>\n                Salwa Corporate Branch <br>Salwa Road, PO Box.1000 <br>Doha, Qatar<br>\n                0250-073882-001<br>\n                QA75QNBA000000000250073882001<br>\n                QNBAQAQA\n            </td>\n        </tr>\n        {% else%}\n        <tr></tr>\n        {% endif %}\n        \n        \n        </table>\n\n\n\n<footer id=\"footer-html\">\n    {% set footer = frappe.db.get_value(\"Letter Head\",doc.letter_head,['footer']) %}\n                {{ footer }}\n     <div class = \"foot\">             \nPage <span class='page'></span> of \n    <span class='topage'></span>  \n</div>           \n</footer>",
