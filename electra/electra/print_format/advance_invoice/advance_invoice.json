 "css": "letter-head{\n    max-width:100px !important;\n    margin-top: -200px !important;\n}\n.foot{\n    text-align:center;\n}\n.print-format{\n    font-size:12px;\n    font-family: 'Soleto';\n    margin-left:5px;\n    margin-right:5px;\n}\nimg{\n    margin-top:-65px;\n}\n@media print\n {\n   thead {display: table-header-group;}\n }\n /*header{*/\n /*    margin-bottom:60px;*/\n /*}*/\n * {\n  box-sizing: border-box;\n  \n}\n\n.row {\n  margin-left:-5px;\n  margin-right:-5px;\n}\n  \n.column {\n  float: left;\n  width: 50%;\n  padding: 5px;\n}\n\n/* Clearfix (clear floats) */\n.row::after {\n  content: \"\";\n  clear: both;\n  display: table;\n}\ntable{\n    padding:-1px;\n}\n\n\nth, td {\n  text-align: left;\n  padding: 16px;\n}\n @page {\n       @bottom-left {\n            content: counter(page) \"https://stackoverflow.com/\" counter(pages);\n        }\n     }",
