od</b></td>\n        <td width=25%>Amount</td>\n    </tr>\n     <tr>\n        <td width=25%><b>Salary & Benefits</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%><b></b></td>\n        <td width=25%></td>\n    </tr>\n    <tr>\n        <td width=25%><b>Salary</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%>{{doc.salary_days}}Days</td>\n        <td width=25%>{{ doc.salary_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Normal Overtime(NOT)</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%>{{doc.not}}Hrs</td>\n        <td width=25%>{{ doc.not_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Holiday Overtime(HOT)</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%>{{doc.hot_hours}}Hrs</td>\n        <td width=25%>{{ doc.hot_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Leave Salary</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%>{{doc.leave_salary_days}}Days</td>\n        <td width=25%>{{ doc.leave_salary_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Gratuity</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%>{{doc.gratuity}}Days</td>\n        <td width=25%>{{ doc.gratuity_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Other Benefits</b></td>\n        <td width=25%><b>Air Ticket</b></td>\n        <td width=25%><b>2 Way</b></td>\n        <td width=25%>{{ doc.other_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25% style=border-right:hidden;><b></b></td>\n        <td width=25% style=border-right:hidden;><b></b></td>\n        <td width=25% ><b>Total</b></td>\n        <td width=25%>{{ doc.total_amount|float|round(2) }}</td>\n    </tr>\n    <tr>\n        <td width=25%><b>Deductions</b></td>\n        <td width=25%><b></b></td>\n        <td width=25%><b></b></td>\n        <td width=25%></td>\n    </tr>